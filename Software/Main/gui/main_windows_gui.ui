  <property name="styleSheet">
   <string notr="true">/* Estilo para la ventana de fondo */
QMainWindow {
    background-color: #F0F4F9; /* Azul muy claro tipo Windows 11 */
}

/* Estilo para los contenedores de los experimentos (Stacked Widget o Frames) */
QStackedWidget, QFrame {
    background-color: transparent;
}

/* Estilo para que tus cajas de texto combinen */
QLineEdit {
    border: 1px solid #D1D9E0;
    border-radius: 6px;
    padding: 6px;
    background-color: #FFFFFF;
    color: #202124;
}

/* Cuando el usuario hace clic en un parámetro */
QLineEdit:focus {
    border: 1px solid #0078D4; /* El azul clásico de selección de Windows */
    background-color: #FFFFFF;
}

/* Si usas QGroupBox para separar los parámetros del ADS1255 */
QGroupBox {
    border: 1px solid #D1D9E0;
    border-radius: 8px;
    margin-top: 1.5em;
    background-color: #FFFFFF;
    font-weight: bold;
}

/* 1. La barra principal en la parte superior */
QMenuBar {
    background-color: #F0F4F9; /* El mismo azul pastel de tu ventana */
    color: #202124;            /* Texto negro carbón */
    border: 1px solid #D1D9E0; /* Borde sutil */
    font-family: &quot;Segoe UI&quot;;
    font-size: 13px;
}

/* 2. Cuando pasas el mouse por encima de una opción (ej. &quot;Experimentos&quot;) */
QMenuBar::item:selected {
    background-color: #E0E7EF; /* Un gris-azul un poco más oscuro */
    border-radius: 4px;
}

/* 3. El menú que se despliega hacia abajo */
QMenu {
    background-color: #FFFFFF; /* Fondo blanco para las opciones */
    color: #202124;            /* Texto negro */
    border: 1px solid #D1D9E0; /* Borde sutil */
    border-radius: 4px;        /* Bordes redondeados modernos */
    padding: 5px;
}

/* 4. Las opciones individuales dentro del menú desplegado */
QMenu::item {
    padding: 8px 25px 8px 10px;
    border-radius: 4px;
}

/* 5. Cuando pasas el mouse sobre una opción específica (ej. &quot;Voltametría&quot;) */
QMenu::item:selected {
    background-color: #CCE5FF; /* Celeste pastel del resaltado */
    color: #000000;
}</string>

    background-color: #E6EBF0; 
    border: 1px solid #B0BCC7;
    border-radius: 0px; /* Bordes rectos industriales */
    
    /* Texto con fuente técnica */
    color: #1A1A1A;
    font-family: &quot;Segoe UI&quot;, &quot;Consolas&quot;; 
    font-weight: bold;
}

QPushButton:hover {
    /* Rojo un poco más intenso al pasar el mouse */
    background-color: #E6EBF0;
    /* Borde azul acero para mantener la coherencia con el resto de la app */
    border: 1px solid #7092BE;
}

QPushButton:pressed {
    /* Rojo más oscuro al hacer clic */
    background-color: #E6EBF0;
    border: 1px solid #5F745B;
}</string>

    <widget class="QPushButton" name="stop_button">
     <property name="enabled">
      <bool>false</bool>
     </property>
     <property name="geometry">
      <rect>
       <x>212</x>
       <y>0</y>
       <width>207</width>
       <height>35</height>
      </rect>
     </property>
     <property name="styleSheet">
      <string notr="true">QPushButton {
    /* Un rojo más saturado y &quot;alerta&quot;, similar al de sistemas modernos */
    background-color: #EF4444; 
    /* Borde en un rojo vino sutil para mantener profundidad sin verse opaco */
    border: 1px solid #B91C1C;
    border-radius: 4px; /* Un toque leve de redondez para sintonizar con Windows 11 */
    
    /* Texto */
    color: #FFFFFF;          /* Texto blanco para máximo contraste sobre el rojo vivo */
    font-family: &quot;Segoe UI&quot;;
    font-weight: bold;
    font-size: 14px;
    text-align: center; 
}

QPushButton:hover {
    /* Rojo un poco más brillante al pasar el mouse */
    background-color: #DC2626;
    /* Usamos el azul Windows 11 que elegiste para el borde de selección */
    border: 1px solid #0078D4; 
}

QPushButton:pressed {
    /* Rojo más profundo al hacer clic */
    background-color: #991B1B;
    border: 1px solid #1A1A1A;
}

/* Cuando está deshabilitado */
QPushButton:disabled {
    background-color: #FCA5A5; /* Un rojo muy deslavado */
    color: #F8F8F8;
    border: 1px solid #E5E7EB;
}</string>
     </property>
     <property name="text">
      <string>Stop Experiment</string>
     </property>
    </widget>

      <property name="styleSheet">
       <string notr="true">QCheckBox {
    spacing: 8px;              /* Espacio entre el cuadro y el texto */
    color: #1A1A1A;            /* Texto casi negro */
    font-family: &quot;Segoe UI&quot;;
    font-size: 13px;
}

/* El cuadro del checkbox */
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid #B0BCC7; /* Borde recto igual que tus botones y barras */
    border-radius: 0px;        /* Bordes totalmente rectos para el look industrial */
    background-color: #FFFFFF; /* Fondo blanco */
}

/* Cuando el mouse pasa por encima */
QCheckBox::indicator:hover {
    border: 1px solid #7092BE; /* Resaltado azul acero */
    background-color: #F0F4F9; /* Fondo azul glaciar muy tenue */
}

/* Cuando está marcado (Checked) */
QCheckBox::indicator:checked {
    background-color: #7092BE; /* Fondo azul acero sólido */
    border: 1px solid #5A769A;
    /* Aquí podrías añadir una imagen de una tilde blanca si la tienes, 
       si no, el cambio de color sólido ya indica que está activo */
}

/* Cuando está deshabilitado */
QCheckBox:disabled {
    color: #A0A0A0;
}

QCheckBox::indicator:disabled {
    background-color: #E6EBF0;
    border: 1px solid #D1D9E0;
}</string>

    color: #202124;            /* Un negro carbón suave, más moderno */
    font-family: &quot;Segoe UI&quot;;   /* Para mantener el estilo Windows 11 */
    font-size: 14px;           /* Tamaño legible para parámetros */
    background-color: transparent; /* Evita que la etiqueta tape el fondo pastel */
}
</string>

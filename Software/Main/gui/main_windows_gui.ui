     <property name="styleSheet">
      <string notr="true">QPushButton {
    /* Un verde esmeralda vivo y moderno */
    background-color: #10B981;
    /* Borde en un verde bosque profundo para dar estructura */
    border: 1px solid #065F46;
    /* Redondeo de 4px para coincidir con el botón Stop y estilo Windows 11 */
    border-radius: 4px; 
    
    /* Texto */
    color: #FFFFFF;                   /* Blanco para legibilidad sobre fondo saturado */
    font-family: &quot;Segoe UI&quot;;
    font-weight: bold;
    font-size: 14px;
    text-align: center; 
}

QPushButton:hover {
    /* Verde un poco más intenso al pasar el mouse */
    background-color: #059669;
    /* Borde con tu nuevo azul Windows para indicar foco */
    border: 1px solid #0078D4; 
}

QPushButton:pressed {
    /* Verde más oscuro al hacer clic para feedback táctil */
    background-color: #047857;
    border: 1px solid #1A1A1A;
}

/* Cuando está deshabilitado */
QPushButton:disabled {
    /* Un verde grisáceo muy suave que indica inactividad */
    background-color: #A7F3D0;
    color: #F0FDF4;
    border: 1px solid #E5E7EB;
}</string>

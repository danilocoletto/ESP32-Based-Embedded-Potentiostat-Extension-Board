      <property name="styleSheet">
       <string notr="true">/* 1. Estilo base del cuadro (el que proporcionaste con ajustes de compatibilidad) */
QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #B0BCC7;
    border-radius: 4px; 
    padding: 5px;
    padding-left: 25px;
    color: #1A1A1A;
    font-family: &quot;Segoe UI&quot;;
    selection-background-color: #7092BE;
}

/* Opcional: Cambiar el color de la flecha cuando pasas el mouse */
QComboBox::down-arrow:hover {
    border-top: 5px solid #7092BE; /* Azul acero al pasar el mouse */
}


/* 4. Estilo de la lista desplegable (Importante para que no salga gris) */
QComboBox QAbstractItemView {
    border: 1px solid #B0BCC7;
    background-color: #FFFFFF;
    selection-color: #FFFFFF;
    padding-left: 15px;
    border-radius: 4px; 
    selection-background-color: #7092BE; /* Azul acero al pasar el mouse [cite: 48, 85] */
    font-family: &quot;Segoe UI&quot;;
    color: #1A1A1A;
}

/* 5. Estado cuando el usuario hace clic o está activo */
QComboBox:focus {
    border: 1px solid #7092BE; /* Resaltado azul acero de tu UI [cite: 75, 99] */
}

/* Opcional: un borde más oscuro cuando el usuario hace clic para escribir */
QComboBox:focus {
    border: 1px solid #7092BE;
}



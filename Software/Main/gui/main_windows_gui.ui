    <property name="styleSheet">
     <string notr="true">QProgressBar {
    border: 1px solid #B0BCC7;       /* Borde más definido y oscuro */
    border-radius: 0px;
    background-color: #E6EBF0;       /* Fondo gris-azul sutilmente más oscuro */
    text-align: center;
    color: #1A1A1A;                  /* Texto casi negro para máxima legibilidad */
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 11px;
    height: 18px;
}

QProgressBar::chunk {
    /* Un azul acero más serio y oscuro */
    background-color: #0078D4;       
    border: 0px;                     /* Sin bordes internos para un look sólido */
}
</string>

    font-family: &quot;Segoe UI&quot;;
    selection-background-color: #7092BE; /* Color de resaltado azul acero */
}

/* Ocultar las flechas de subir y bajar */
QSpinBox::up-button, QSpinBox::down-button {
    width: 0px;
    border: none;
    background: transparent;
}

/* Opcional: un borde más oscuro cuando el usuario hace clic para escribir */
QSpinBox:focus {
    border: 1px solid #7092BE;
}</string>

	(text "+5 & +3.3V POWER SUPPLY"
		(exclude_from_sim no)
		(at 251.46 130.81 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "0acdd2a4-02b7-4ce9-adc0-13e79664aadf")
	)
	(text "Notes: For a future design upgrade, more protection consideration\nshould/can be added, like ESD diodes or Reverse Polarity \nProtection Diodes at the Power Supply entry connector.\nCLKIN pin conector for ADS1255 can be added too.\nProtection diodes to the 5V and 3.3V pins from the main 30-pin\nconector should also be added."
		(exclude_from_sim no)
		(at 244.856 154.94 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "2c3fb00d-a1a8-4403-9938-f290f0465890")
	)
	(text "VCC AND GND PINS WERE \nINVERTED IN THE FOOTPRINT. \nTHEY WERE CORRECTED.\nFOOTPRINT MODIFICATED TO \nMATCH THE STANDARD USB DISPOSITION.\nTHIS WAS A DANGEROUS PROBLEM, \nPLEASE IF YOU USE THIS DESIGN. \nMAKE SURE TO DOUBLE CHECK \nTHIS BEFORE POWERING UP THE SYSTEM.\n\n"
		(exclude_from_sim no)
		(at 147.066 176.022 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
				(color 255 0 4 1)
			)
		)
		(uuid "6871dded-51e5-45a7-bde0-5effd9a87178")
	)
	(text "System can be powered with 6V\nor more. A 9V power supply its\nstill a safe option.\nGOING CLOSE TO 12 - 15 V \nIS NOT RECOMMENDED. "
		(exclude_from_sim no)
		(at 147.32 155.448 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
				(color 0 0 255 1)
			)
		)
		(uuid "e8c56af6-a34b-4bf1-8193-5142c770e1b4")
	)

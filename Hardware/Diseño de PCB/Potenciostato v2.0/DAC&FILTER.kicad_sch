	(text "IF THE BOARD IS USE WITH AN ESP32 A LEVEL SHIFTER \nFOR THE I2C COMMUNICATION IS NEDDED.\n\nPULL UPS RESISTOR OF THE MAX5217 ARE CONNECTED TO 5V\nBECAUSE MAX5217 IS POWERED WITH 5V AND A HIGH LEVEL\nIS 0.7*VCC ~ 3.4 V SO 3.3V LOGIC CAN BE TRICKY AS IT\nMAY BE NOT ENOUGH.\nMAX 5217 NEEDS TO BE POWERED WITH 5V IN ORDER TO BE\n\nYOU MAY CONSIDERED ADDING A LEVEL SHIFTER TO THIS DESIGN OR USING AN EXTERNAL ONE.\nABLE TO GENERATE SIGNAL FROM 0 TO 5V AT THE OUTPUT."
		(exclude_from_sim no)
		(at 87.884 133.604 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
				(color 255 6 0 1)
			)
		)
		(uuid "0b8e49ef-6345-4b1d-9bfb-b0e18c781baa")
	)
	(text "REPLACED FOR OPA2320\n"
		(exclude_from_sim no)
		(at 197.866 139.446 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "3ce2e81d-4769-4818-b0f9-dae366b2717a")
	)
	(text "MAX4477ASA+ IS NOT TRULY RAIL TO RAIL\nIT GOES TO VSS BUT TRIMS AT VDD - 1.6V\nNEEDS REPLACEMENT TO ACHIEVE TRUE RANGE FROM -2.5V TO 2.5V\nOPA2320 IS A GOOD REPLACEMENT\n\n"
		(exclude_from_sim no)
		(at 198.12 133.858 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
				(color 255 0 6 1)
			)
		)
		(uuid "897eaf5f-69b1-490b-9add-f667e23eb6b4")
	)
